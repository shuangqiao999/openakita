{
  "name": "@openakita/plugin-ui-sdk",
  "version": "1.0.0",
  "description": "Frontend SDK for OpenAkita Plugin 2.0 UI — communicates with the host via postMessage bridge",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["openakita", "plugin", "sdk", "bridge"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
