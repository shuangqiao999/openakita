{
  "id": "tongyi-image",
  "name": "通义生图",
  "name_i18n": { "en": "Tongyi Image" },
  "version": "0.1.0",
  "description": "基于 DashScope 的 AI 图片生成 — 文生图、图像编辑、电商套图、风格重绘、背景生成、画面扩展、涂鸦作画",
  "description_i18n": {
    "en": "AI image generation powered by DashScope — text-to-image, image editing, e-commerce suite, style repaint, background generation, outpainting, sketch-to-image"
  },
  "type": "python",
  "entry": "plugin.py",
  "permissions": [
    "tools.register",
    "routes.register",
    "hooks.basic",
    "config.read",
    "config.write",
    "data.own",
    "brain.access"
  ],
  "requires": {
    "openakita": ">=1.27.0",
    "plugin_api": "~1",
    "plugin_ui_api": "~1"
  },
  "provides": {
    "tools": ["tongyi_image_create", "tongyi_image_status", "tongyi_image_list"],
    "routes": true
  },
  "ui": {
    "entry": "ui/dist/index.html",
    "title": "通义生图",
    "title_i18n": { "en": "Tongyi Image" },
    "sidebar_group": "apps",
    "permissions": ["upload", "download", "notifications", "theme", "clipboard"]
  }
}
